{
  "name": "espumatex",
  "version": "0.1.0",
  "private": true,
  "description": "E-commerce de espumas, tecidos, manta acrílica e fibras — venda por metro / m² / m³",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @espumatex/api dev",
    "dev:web": "pnpm --filter @espumatex/web dev",
    "dev": "pnpm --parallel --filter @espumatex/api --filter @espumatex/web dev",
    "db:generate": "pnpm --filter @espumatex/db generate",
    "db:migrate": "pnpm --filter @espumatex/db migrate",
    "db:studio": "pnpm --filter @espumatex/db studio",
    "db:seed": "pnpm --filter @espumatex/db seed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "clean": "pnpm -r clean && rimraf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
