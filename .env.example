# ============================================================
# .env — Variáveis de ambiente do monorepo Espumatex
# Copie pra .env e preencha. NÃO comite no git.
# ============================================================

# ----- Banco de dados -----
DATABASE_URL="postgresql://user:senha@localhost:5432/espumatex?schema=public"

# ----- App / URLs -----
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000

# Em DEV use localhost. Em PROD (Vercel/Railway), troque para os domínios reais.
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Domínio público (PROD) — usado em metadata, OG, sitemap, e-mails
PUBLIC_WEB_URL="https://www.espumaetex.com.br"
PUBLIC_API_URL="https://api.espumaetex.com.br"

# Aliases que o Next lê em build-time (precisa do prefixo NEXT_PUBLIC_)
NEXT_PUBLIC_WEB_URL="https://www.espumaetex.com.br"
NEXT_PUBLIC_API_URL="https://api.espumaetex.com.br"

# ----- JWT (autenticação) -----
JWT_SECRET="troque-isso-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="outro-segredo-diferente-aqui"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ----- Redis (cache/sessão/filas) -----
REDIS_URL="redis://localhost:6379"

# ----- Mercado Pago (pagamentos) -----
# https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN="TEST-..."
MP_PUBLIC_KEY="TEST-..."
MP_WEBHOOK_SECRET="..."

# ----- Melhor Envio (frete) -----
# https://melhorenvio.com.br/
MELHOR_ENVIO_TOKEN="..."
MELHOR_ENVIO_SANDBOX=true
MELHOR_ENVIO_FROM_CEP="01310100"

# ----- PlugNotas (NF-e) -----
# https://plugnotas.com.br/
PLUGNOTAS_API_KEY="..."
PLUGNOTAS_SANDBOX=true
EMITTER_CNPJ="00000000000000"
EMITTER_IE="ISENTO"

# ----- Resend (e-mail transacional) -----
RESEND_API_KEY="re_..."
EMAIL_FROM="contato@espumaetex.com.br"

# ----- WhatsApp (Meta Cloud API) -----
WHATSAPP_TOKEN="..."
WHATSAPP_PHONE_ID="..."
WHATSAPP_VERIFY_TOKEN="..."

# ----- Storage (Cloudflare R2 ou AWS S3) -----
S3_ENDPOINT="https://....r2.cloudflarestorage.com"
S3_BUCKET="espumaetex-media"
S3_ACCESS_KEY="..."
S3_SECRET_KEY="..."
S3_PUBLIC_URL="https://media.espumaetex.com.br"

# ----- Loja: regiões atendidas (v1: somente SP) -----
ALLOWED_SHIPPING_STATES="SP"
